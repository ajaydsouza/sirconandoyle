---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;
---
<nav aria-label="breadcrumb" class="text-sm text-[#8b7355] mb-6">
  <ol class="flex flex-wrap items-center gap-1">
    {crumbs.map((crumb, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span aria-hidden="true" class="text-[#c9a961]">›</span>}
        {crumb.href
          ? <a href={crumb.href} class="text-[#d4af37] hover:text-[#c9a961] hover:underline transition-colors duration-300">{crumb.label}</a>
          : <span class="text-[#e8dcc8]">{crumb.label}</span>
        }
      </li>
    ))}
  </ol>
</nav>
