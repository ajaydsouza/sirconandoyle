---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;
---
<nav aria-label="breadcrumb" class="text-sm text-stone-500 mb-6">
  <ol class="flex flex-wrap items-center gap-1">
    {crumbs.map((crumb, i) => {
      let href = crumb.href;
      if (href && href.startsWith('/') && !href.startsWith('//')) {
        // Ensure we don't double slash. import.meta.env.BASE_URL usually is /sirconandoyle/
        href = href === '/' 
          ? import.meta.env.BASE_URL 
          : `${import.meta.env.BASE_URL}${href.slice(1)}`;
      }
      return (
        <li class="flex items-center gap-1">
          {i > 0 && <span aria-hidden="true" class="text-stone-300">›</span>}
          {href
            ? <a href={href} class="hover:text-stone-800 hover:underline">{crumb.label}</a>
            : <span class="text-stone-800">{crumb.label}</span>
          }
        </li>
      );
    })}
  </ol>
</nav>
