---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'The complete works of Sir Arthur Conan Doyle — Sherlock Holmes and beyond.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} — Sir Arthur Conan Doyle</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,600;1,400&family=Great+Vibes&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col bg-[#d4c5a9]" style="background-image: repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(0,0,0,.03) 2px, rgba(0,0,0,.03) 4px), repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,.03) 2px, rgba(0,0,0,.03) 4px); background-size: 50px 50px;">

    <header class="bg-white border-b border-stone-200 shadow-sm">
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-center gap-6">
        <!-- Logo: portrait + site name + tagline -->
        <a href="/" class="flex items-center gap-3 shrink-0">
          <img src="/images/posts/SACD.jpg" alt="Sir Arthur Conan Doyle" class="h-16 w-16 object-cover rounded shadow-sm" />
          <div>
            <span class="block text-3xl leading-tight text-[#3a5f8a]" style="font-family: 'Great Vibes', cursive;">Sir Arthur Conan Doyle</span>
            <span class="block text-xs text-stone-500 tracking-wide mt-0.5">His Life, All His Works and more...</span>
          </div>
        </a>

        <!-- Navigation -->
        <nav class="ml-auto flex items-center gap-6 text-sm text-stone-600 font-medium">
          <a href="/" class="hover:text-stone-900 transition-colors">Home</a>
          <a href="/canon/" class="hover:text-stone-900 transition-colors">The Canon</a>
          <a href="/novels/" class="hover:text-stone-900 transition-colors">Novels</a>
          <a href="/who-is-doyle/" class="hover:text-stone-900 transition-colors whitespace-nowrap">Who is Doyle?</a>
          <!-- Search icon -->
          <a href="/search/" aria-label="Search" class="hover:text-stone-900 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <main class="flex-1 py-8">
      <div class="max-w-5xl mx-auto px-4">
        <div class="bg-white bg-opacity-95 rounded-lg shadow-sm overflow-hidden">
          <slot />
        </div>
      </div>
    </main>

    <footer class="border-t-2 border-amber-900 bg-white text-amber-900 py-8 mt-4">
      <div class="max-w-5xl mx-auto px-4">
        <nav class="flex flex-wrap justify-center gap-6 text-sm mb-6 pb-6 border-b border-amber-200">
          <a href="/" class="hover:text-amber-700">Home</a>
          <a href="/canon/" class="hover:text-amber-700">The Canon</a>
          <a href="/novels/" class="hover:text-amber-700">Novels</a>
          <a href="/who-is-doyle/" class="hover:text-amber-700">Who is Doyle?</a>
          <a href="/search/" class="hover:text-amber-700">Search</a>
          <a href="/privacy-policy/" class="hover:text-amber-700">Privacy Policy</a>
          <a href="/disclaimer/" class="hover:text-amber-700">Disclaimer</a>
          <a href="/sitemap.xml" class="hover:text-amber-700">Sitemap</a>
        </nav>
        <p class="text-center text-xs leading-relaxed">This is an unofficial fan site dedicated to Sir Arthur Conan Doyle and his works. This site is not affiliated with, endorsed by, or connected to the Arthur Conan Doyle Estate Ltd. All Sherlock Holmes stories, characters, and related elements are the intellectual property of the Arthur Conan Doyle Estate Ltd and/or their respective copyright holders. Content from the original works is used under fair use principles for commentary, criticism, research, and appreciation purposes only. All original content created for this fan site is the property of sirconandoyle.com. This website is maintained by a fan for fans and is intended for informational and entertainment purposes only.</p>
      </div>
    </footer>
  </body>
</html>
