---
import { SEO } from 'astro-seo';
import '../styles/global.css';
import { Image } from 'astro:assets';
import logo from '../assets/images/posts/SACD.jpg';

// Local Font Imports (Fontsource)
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/700.css';
import '@fontsource/cormorant-garamond/400-italic.css';
import '@fontsource/great-vibes';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  nofollow?: boolean;
}

const {
  title,
  description = 'The complete works of Sir Arthur Conan Doyle — Sherlock Holmes and beyond.',
  image = logo.src,
  canonical = Astro.url.href,
  noindex = false,
  nofollow = false
} = Astro.props;

const siteTitle = 'Sir Arthur Conan Doyle';
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <SEO
      title={fullTitle}
      description={description}
      canonical={canonical}
      noindex={noindex}
      nofollow={nofollow}
      openGraph={{
        basic: {
          title: fullTitle,
          type: "website",
          image: new URL(image, Astro.url).href,
        },
        optional: {
          description: description,
          siteName: siteTitle
        }
      }}
      twitter={{
        card: "summary_large_image",
        title: fullTitle,
        description: description,
        image: new URL(image, Astro.url).href,
      }}
      extend={{
        meta: [
          { name: "theme-color", content: "#3a5f8a" }
        ],
        link: [
          { rel: "icon", type: "image/x-icon", href: `${import.meta.env.BASE_URL}favicon.ico` },
          { rel: "icon", type: "image/svg+xml", href: `${import.meta.env.BASE_URL}favicon.svg` },
          { rel: "icon", type: "image/png", sizes: "32x32", href: `${import.meta.env.BASE_URL}favicon-32x32.png` },
          { rel: "apple-touch-icon", sizes: "180x180", href: `${import.meta.env.BASE_URL}apple-touch-icon.png` },
          { rel: "manifest", href: `${import.meta.env.BASE_URL}manifest.webmanifest` }
        ]
      }}
    />

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-[#d4c5a9]" style="background-image: repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(0,0,0,.03) 2px, rgba(0,0,0,.03) 4px), repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,.03) 2px, rgba(0,0,0,.03) 4px); background-size: 50px 50px;">

    <header class="bg-white border-b border-stone-200 shadow-sm relative z-50">
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
        <!-- Logo: portrait + site name + tagline -->
        <a href={import.meta.env.BASE_URL} class="flex items-center gap-3 shrink-0">
          <img src={logo.src} alt="Sir Arthur Conan Doyle" class="h-16 w-16 object-cover rounded shadow-sm" loading="eager" fetchpriority="high" />
          <div class="hidden sm:block">
            <span class="block text-3xl leading-tight text-[#3a5f8a]" style="font-family: 'Great Vibes', cursive;">Sir Arthur Conan Doyle</span>
            <span class="block text-xs text-stone-500 tracking-wide mt-0.5">His Life, All His Works and more...</span>
          </div>
        </a>

        <!-- Mobile Controls -->
        <div class="flex items-center gap-2 lg:hidden">
          <button id="search-toggle-mobile" aria-label="Search" class="p-2 text-stone-600 hover:text-stone-900 cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
            </svg>
          </button>
          <button id="mobile-menu-toggle" aria-label="Toggle menu" class="p-2 text-stone-600 hover:text-stone-900 cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

        <!-- Desktop Navigation -->
        <nav class="hidden lg:flex items-center gap-6 text-sm text-stone-600 font-medium">
          <a href={import.meta.env.BASE_URL} class="hover:text-stone-900 transition-colors">Home</a>

          <!-- The Canon dropdown -->
          <div class="relative group">
            <a href={`${import.meta.env.BASE_URL}canon/`} class="flex items-center gap-1 hover:text-stone-900 transition-colors">
              The Canon
              <svg class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
            <div class="absolute top-full left-0 pt-2 hidden group-hover:block z-50">
              <div class="bg-white border border-stone-200 shadow-lg rounded-lg py-1 min-w-56">
                <a href={`${import.meta.env.BASE_URL}canon/novels/`} class="block px-4 py-2 text-stone-700 hover:bg-amber-50 hover:text-stone-900 transition-colors">The Novels of Sherlock Holmes</a>
                <a href={`${import.meta.env.BASE_URL}canon/adventures/`} class="block px-4 py-2 text-stone-700 hover:bg-amber-50 hover:text-stone-900 transition-colors">The Adventures of Sherlock Holmes</a>
                <a href={`${import.meta.env.BASE_URL}canon/memoirs/`} class="block px-4 py-2 text-stone-700 hover:bg-amber-50 hover:text-stone-900 transition-colors">The Memoirs of Sherlock Holmes</a>
                <a href={`${import.meta.env.BASE_URL}canon/casebook/`} class="block px-4 py-2 text-stone-700 hover:bg-amber-50 hover:text-stone-900 transition-colors">The Case Book of Sherlock Holmes</a>
                <a href={`${import.meta.env.BASE_URL}canon/return/`} class="block px-4 py-2 text-stone-700 hover:bg-amber-50 hover:text-stone-900 transition-colors">The Return of Sherlock Holmes</a>
                <a href={`${import.meta.env.BASE_URL}canon/last-bow/`} class="block px-4 py-2 text-stone-700 hover:bg-amber-50 hover:text-stone-900 transition-colors">His Last Bow</a>
              </div>
            </div>
          </div>

          <!-- Novels dropdown -->
          <div class="relative group">
            <a href={`${import.meta.env.BASE_URL}novels/`} class="flex items-center gap-1 hover:text-stone-900 transition-colors">
              Novels
              <svg class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
            <div class="absolute top-full left-0 pt-2 hidden group-hover:block z-50">
              <div class="bg-white border border-stone-200 shadow-lg rounded-lg py-1 min-w-48">
                <a href={`${import.meta.env.BASE_URL}novels/lost-world/`} class="block px-4 py-2 text-stone-700 hover:bg-amber-50 hover:text-stone-900 transition-colors">The Lost World</a>
                <a href={`${import.meta.env.BASE_URL}the-lost-world-tv-series/`} class="block px-4 py-2 text-stone-700 hover:bg-amber-50 hover:text-stone-900 transition-colors">The Lost World TV Series</a>
              </div>
            </div>
          </div>

          <a href={`${import.meta.env.BASE_URL}who-is-doyle/`} class="hover:text-stone-900 transition-colors whitespace-nowrap">Who is Doyle?</a>
          <!-- Search toggle button -->
          <button id="search-toggle-desktop" aria-label="Search" class="hover:text-stone-900 transition-colors cursor-pointer ml-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
            </svg>
          </button>
        </nav>
      </div>

      <!-- Mobile Menu Drawer -->
      <div id="mobile-menu-drawer" class="fixed inset-y-0 right-0 w-72 bg-white shadow-2xl z-[60] transform translate-x-full transition-transform duration-300 ease-in-out lg:hidden h-screen overflow-y-auto">
        <div class="p-6">
          <div class="flex items-center justify-between mb-8 pb-4 border-b border-stone-100">
            <span class="font-serif text-xl text-stone-900">Navigation</span>
            <button id="mobile-menu-close" aria-label="Close menu" class="text-stone-400 hover:text-stone-900 text-3xl leading-none cursor-pointer">&times;</button>
          </div>
          <nav class="flex flex-col gap-1 text-stone-700 font-medium font-serif">
            <a href={import.meta.env.BASE_URL} class="text-lg hover:text-stone-900 transition-colors border-b border-stone-100 pb-3 mb-2">Home</a>
            <a href={`${import.meta.env.BASE_URL}canon/`} class="text-lg hover:text-stone-900 transition-colors">The Canon</a>
            <div class="pl-4 flex flex-col gap-1 py-2 border-b border-stone-100 mb-2">
              <a href={`${import.meta.env.BASE_URL}canon/novels/`} class="text-sm text-stone-500 hover:text-stone-900 transition-colors py-1">The Novels of Sherlock Holmes</a>
              <a href={`${import.meta.env.BASE_URL}canon/adventures/`} class="text-sm text-stone-500 hover:text-stone-900 transition-colors py-1">The Adventures of Sherlock Holmes</a>
              <a href={`${import.meta.env.BASE_URL}canon/memoirs/`} class="text-sm text-stone-500 hover:text-stone-900 transition-colors py-1">The Memoirs of Sherlock Holmes</a>
              <a href={`${import.meta.env.BASE_URL}canon/casebook/`} class="text-sm text-stone-500 hover:text-stone-900 transition-colors py-1">The Case Book of Sherlock Holmes</a>
              <a href={`${import.meta.env.BASE_URL}canon/return/`} class="text-sm text-stone-500 hover:text-stone-900 transition-colors py-1">The Return of Sherlock Holmes</a>
              <a href={`${import.meta.env.BASE_URL}canon/last-bow/`} class="text-sm text-stone-500 hover:text-stone-900 transition-colors py-1">His Last Bow</a>
            </div>
            <a href={`${import.meta.env.BASE_URL}novels/`} class="text-lg hover:text-stone-900 transition-colors">Novels</a>
            <div class="pl-4 flex flex-col gap-1 py-2 border-b border-stone-100 mb-2">
              <a href={`${import.meta.env.BASE_URL}novels/lost-world/`} class="text-sm text-stone-500 hover:text-stone-900 transition-colors py-1">The Lost World</a>
              <a href={`${import.meta.env.BASE_URL}the-lost-world-tv-series/`} class="text-sm text-stone-500 hover:text-stone-900 transition-colors py-1">The Lost World TV Series</a>
            </div>
            <a href={`${import.meta.env.BASE_URL}who-is-doyle/`} class="text-lg hover:text-stone-900 transition-colors border-b border-stone-100 pb-3 mb-2">Who is Doyle?</a>
            <a href={`${import.meta.env.BASE_URL}search/`} class="text-lg hover:text-stone-900 transition-colors pb-2">Search Site</a>
          </nav>
          
          <div class="mt-20 pt-8 border-t border-stone-100 italic text-stone-400 text-xs text-center leading-relaxed px-4">
            "Eliminate all other factors, and the one which remains must be the truth."
          </div>
        </div>
      </div>

      <!-- Backdrop -->
      <div id="mobile-menu-backdrop" class="fixed inset-0 bg-stone-900/50 backdrop-blur-sm z-[55] hidden opacity-0 transition-opacity duration-300 lg:hidden"></div>

      <div id="search-bar" class="hidden border-t border-stone-100 bg-stone-50 relative z-[50]">
        <div class="max-w-5xl mx-auto px-4 py-3">
          <form action={`${import.meta.env.BASE_URL}search/`} method="get" class="flex items-center gap-3">
            <div class="relative flex-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 absolute left-3 top-1/2 -translate-y-1/2 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
              </svg>
              <input
                type="text"
                name="q"
                id="search-input"
                placeholder="Search Sir Arthur Conan Doyle…"
                autocomplete="off"
                class="w-full border border-stone-200 rounded-full pl-9 pr-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 bg-white shadow-inner transition-all"
              />
            </div>
            <button type="submit" class="px-5 py-2 bg-stone-800 text-white text-sm font-medium rounded-full hover:bg-stone-700 transition-all shadow-sm">Search</button>
            <button type="button" id="search-close" aria-label="Close search" class="text-stone-400 hover:text-stone-700 px-1 text-2xl leading-none transition-colors hidden sm:block">&times;</button>
          </form>
        </div>
      </div>
    </header>

    <main class="flex-1 py-8">
      <div class="max-w-5xl mx-auto px-4">
        <div class="bg-white bg-opacity-95 rounded-lg shadow-sm overflow-hidden">
          <slot />
        </div>
      </div>
    </main>

    <footer class="border-t-2 border-amber-900 bg-white text-amber-900 py-8 mt-4">
      <div class="max-w-5xl mx-auto px-4">
        <nav class="flex flex-wrap justify-center gap-6 text-sm mb-6 pb-6 border-b border-amber-200">
          <a href={import.meta.env.BASE_URL} class="hover:text-amber-700">Home</a>
          <a href={`${import.meta.env.BASE_URL}canon/`} class="hover:text-amber-700">The Canon</a>
          <a href={`${import.meta.env.BASE_URL}novels/`} class="hover:text-amber-700">Novels</a>
          <a href={`${import.meta.env.BASE_URL}who-is-doyle/`} class="hover:text-amber-700">Who is Doyle?</a>
          <a href={`${import.meta.env.BASE_URL}search/`} class="hover:text-amber-700">Search</a>
          <a href={`${import.meta.env.BASE_URL}privacy-policy/`} class="hover:text-amber-700">Privacy Policy</a>
          <a href={`${import.meta.env.BASE_URL}disclaimer/`} class="hover:text-amber-700">Disclaimer</a>
          <a href={`${import.meta.env.BASE_URL}sitemap-index.xml`} class="hover:text-amber-700">Sitemap</a>
        </nav>
        <p class="text-center text-xs leading-relaxed">This is an unofficial fan site dedicated to Sir Arthur Conan Doyle and his works. This site is not affiliated with, endorsed by, or connected to the Arthur Conan Doyle Estate Ltd. All Sherlock Holmes stories, characters, and related elements are the intellectual property of the Arthur Conan Doyle Estate Ltd and/or their respective copyright holders. Content from the original works is used under fair use principles for commentary, criticism, research, and appreciation purposes only. All original content created for this fan site is the property of sirconandoyle.com. This website is maintained by a fan for fans and is intended for informational and entertainment purposes only.</p>
      </div>
    </footer>
  </body>
</html>

<script>
  const toggleDesktop = document.getElementById('search-toggle-desktop');
  const toggleMobile = document.getElementById('search-toggle-mobile');
  const bar = document.getElementById('search-bar');
  const input = /** @type {HTMLInputElement|null} */ (document.getElementById('search-input'));
  const closeBtn = document.getElementById('search-close');
  
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileClose = document.getElementById('mobile-menu-close');
  const drawer = document.getElementById('mobile-menu-drawer');
  const backdrop = document.getElementById('mobile-menu-backdrop');

  const toggleSearch = () => {
    const hidden = bar?.classList.toggle('hidden');
    if (!hidden) input?.focus();
    // Close mobile drawer if search is opened
    closeDrawer();
  };

  toggleDesktop?.addEventListener('click', toggleSearch);
  toggleMobile?.addEventListener('click', toggleSearch);
  closeBtn?.addEventListener('click', () => bar?.classList.add('hidden'));

  const openDrawer = () => {
    drawer?.classList.remove('translate-x-full');
    backdrop?.classList.remove('hidden');
    setTimeout(() => backdrop?.classList.add('opacity-100'), 10);
    document.body.style.overflow = 'hidden';
    bar?.classList.add('hidden');
  };

  const closeDrawer = () => {
    drawer?.classList.add('translate-x-full');
    backdrop?.classList.remove('opacity-100');
    setTimeout(() => backdrop?.classList.add('hidden'), 300);
    document.body.style.overflow = '';
  };

  mobileToggle?.addEventListener('click', openDrawer);
  mobileClose?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      bar?.classList.add('hidden');
      closeDrawer();
    }
  });
</script>
