---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

export async function getStaticPaths() {
  function isIntroSlug(slug: string, novel: string): boolean {
    return slug === novel || slug === `the-${novel}`;
  }
  const allEntries = await getCollection('novels');
  const novelSlugs = [...new Set(allEntries.map(e => e.id.split('/')[0]))];

  return novelSlugs.map(novel => {
    const entries = allEntries
      .filter(e => e.id.split('/')[0] === novel)
      .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
    return { params: { novel }, props: { entries } };
  });
}

const { novel } = Astro.params;
const { entries } = Astro.props;

function isIntroSlug(slug: string, novelDir: string): boolean {
  return slug === novelDir || slug === `the-${novelDir}`;
}

const introEntry = entries.find(e => isIntroSlug(e.id.split('/').pop()!, novel));
const chapters   = entries.filter(e => !isIntroSlug(e.id.split('/').pop()!, novel));
const novelTitle = introEntry?.data.title ?? entries[0]?.data.title ?? novel;

const { Content: IntroContent } = introEntry ? await render(introEntry) : { Content: null };
---
<Base
  title={novelTitle}
  description={introEntry?.data.description}
  image={introEntry?.data.coverImage?.src}
>
  <div class="max-w-[70ch] mx-auto px-4 py-10">
    <Breadcrumb crumbs={[
      { label: 'Home',   href: import.meta.env.BASE_URL },
      { label: 'Novels', href: `${import.meta.env.BASE_URL}novels/` },
      { label: novelTitle },
    ]} />

    <h1 class="font-serif text-3xl font-semibold text-stone-900 mb-8">{novelTitle}</h1>

    {introEntry && IntroContent && (
      <article class="prose mb-10">
        <IntroContent />
      </article>
    )}

    {chapters.length > 0 && (
      <ol class="space-y-1">
        {chapters.map((entry, i) => {
          const slug = entry.id.split('/').pop();
          return (
            <li>
              <a
                href={`${import.meta.env.BASE_URL}novels/${novel}/${slug}/`}
                class="flex items-baseline gap-3 px-4 py-3 rounded-lg hover:bg-amber-50 group transition-colors"
              >
                <span class="text-stone-400 text-sm w-6 shrink-0 text-right">{i + 1}.</span>
                <span class="font-serif text-stone-800 group-hover:text-amber-900">{entry.data.title}</span>
              </a>
            </li>
          );
        })}
      </ol>
    )}
  </div>
</Base>
