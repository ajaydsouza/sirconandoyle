---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

export async function getStaticPaths() {
  const allEntries = await getCollection('novels');

  // Collect unique novel slugs
  const novelSlugs = [...new Set(allEntries.map(e => e.id.split('/')[0]))];

  return novelSlugs.map(novel => {
    const entries = allEntries
      .filter(e => e.id.split('/')[0] === novel)
      .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
    return { params: { novel }, props: { entries } };
  });
}

const { novel } = Astro.params;
const { entries } = Astro.props;

// Use the title of the first entry (order=1, the intro/overview post) as the novel title
const novelTitle = entries[0]?.data.title ?? novel;
---
<Base title={novelTitle}>
  <div class="max-w-3xl mx-auto px-4 py-10">
    <Breadcrumb crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Novels', href: '/novels/' },
      { label: novelTitle },
    ]} />

    <h1 class="font-serif text-3xl font-semibold text-stone-900 mb-8">{novelTitle}</h1>

    <ol class="space-y-1">
      {entries.map((entry, i) => {
        const slug = entry.id.split('/').pop();
        return (
          <li>
            <a
              href={`/novels/${novel}/${slug}/`}
              class="flex items-baseline gap-3 px-4 py-3 rounded-lg hover:bg-amber-50 group transition-colors"
            >
              <span class="text-stone-400 text-sm w-6 shrink-0 text-right">{i + 1}.</span>
              <span class="font-serif text-stone-800 group-hover:text-amber-900">{entry.data.title}</span>
            </a>
          </li>
        );
      })}
    </ol>
  </div>
</Base>
