---
import { getCollection, render } from 'astro:content';
import Base from '../../../../layouts/Base.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import StoryNav from '../../../../components/StoryNav.astro';

export async function getStaticPaths() {
  const NOVEL_LABELS: Record<string, string> = {
    'a-study-in-scarlet':        'A Study in Scarlet',
    'sign-of-four':              'The Sign of Four',
    'hound-of-the-baskervilles': 'The Hound of the Baskervilles',
    'valley-of-fear':            'The Valley of Fear',
  };

  const allEntries = await getCollection('canon', e => e.id.startsWith('novels/'));

  const paths = [];
  for (const novel of Object.keys(NOVEL_LABELS)) {
    const entries = allEntries
      .filter(e => e.id.split('/')[1] === novel)
      .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

    for (let i = 0; i < entries.length; i++) {
      const entry = entries[i];
      const slug = entry.id.split('/').pop();
      if (!slug) continue;
      paths.push({
        params: { novel, slug },
        props: {
          entry,
          novelLabel: NOVEL_LABELS[novel],
          prev: i > 0 ? { title: entries[i - 1].data.title, href: `${import.meta.env.BASE_URL}canon/novels/${novel}/${entries[i - 1].id.split('/').pop()}/` } : null,
          next: i < entries.length - 1 ? { title: entries[i + 1].data.title, href: `${import.meta.env.BASE_URL}canon/novels/${novel}/${entries[i + 1].id.split('/').pop()}/` } : null,
        },
      });
    }
  }
  return paths;
}

const { novel } = Astro.params;
const { entry, novelLabel, prev, next } = Astro.props;
const { Content } = await render(entry);
const { title, description, coverImage } = entry.data;
---
<Base title={title} description={description} image={coverImage?.src}>
  <div class="max-w-[70ch] mx-auto px-4 py-10">
    <Breadcrumb crumbs={[
      { label: 'Home', href: import.meta.env.BASE_URL },
      { label: 'The Canon', href: `${import.meta.env.BASE_URL}canon/` },
      { label: 'Novels', href: `${import.meta.env.BASE_URL}canon/novels/` },
      { label: novelLabel, href: `${import.meta.env.BASE_URL}canon/novels/${novel}/` },
      { label: entry.data.title },
    ]} />

    <h1 class="font-serif text-3xl font-semibold text-stone-900 mb-8">{entry.data.title}</h1>

    <article class="prose">
      <Content />
    </article>

    <StoryNav prev={prev} next={next} />
  </div>
</Base>
