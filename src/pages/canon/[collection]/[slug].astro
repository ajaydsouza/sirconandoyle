---
// Handles /canon/adventures/a-scandal-in-bohemia/ etc. (short story collections only, not Holmes novels)
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import StoryNav from '../../../components/StoryNav.astro';

export async function getStaticPaths() {
  const LABELS: Record<string, string> = {
    adventures: 'The Adventures of Sherlock Holmes',
    memoirs:    'The Memoirs of Sherlock Holmes',
    return:     'The Return of Sherlock Holmes',
    'last-bow': 'His Last Bow',
    casebook:   'The Case Book of Sherlock Holmes',
  };

  const allEntries = await getCollection('canon', e => !e.id.startsWith('novels/'));

  const paths = [];
  for (const collection of Object.keys(LABELS)) {
    const entries = allEntries
      .filter(e => e.data.collection === collection)
      .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

    for (let i = 0; i < entries.length; i++) {
      const entry = entries[i];
      const slug = entry.id.split('/').pop()!;
      paths.push({
        params: { collection, slug },
        props: {
          entry,
          collectionLabel: LABELS[collection],
          prev: i > 0 ? { title: entries[i - 1].data.title, href: `/canon/${collection}/${entries[i - 1].id.split('/').pop()}/` } : null,
          next: i < entries.length - 1 ? { title: entries[i + 1].data.title, href: `/canon/${collection}/${entries[i + 1].id.split('/').pop()}/` } : null,
        },
      });
    }
  }
  return paths;
}

const { collection } = Astro.params;
const { entry, collectionLabel, prev, next } = Astro.props;
const { Content } = await render(entry);
---
<Base title={entry.data.title}>
  <div class="max-w-[70ch] mx-auto px-4 py-10">
    <Breadcrumb crumbs={[
      { label: 'Home', href: '/' },
      { label: 'The Canon', href: '/canon/' },
      { label: collectionLabel, href: `/canon/${collection}/` },
      { label: entry.data.title },
    ]} />

    <h1 class="font-serif text-3xl font-semibold text-stone-900 mb-8">{entry.data.title}</h1>

    <article class="prose">
      <Content />
    </article>

    <StoryNav prev={prev} next={next} />
  </div>
</Base>
