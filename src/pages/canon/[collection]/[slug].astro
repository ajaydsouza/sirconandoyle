---
// Handles /canon/adventures/a-scandal-in-bohemia/ etc. (short story collections only, not Holmes novels)
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import StoryNav from '../../../components/StoryNav.astro';

export async function getStaticPaths() {
  const LABELS: Record<string, string> = {
    adventures: 'The Adventures of Sherlock Holmes',
    memoirs:    'The Memoirs of Sherlock Holmes',
    return:     'The Return of Sherlock Holmes',
    'last-bow': 'His Last Bow',
    casebook:   'The Case Book of Sherlock Holmes',
  };

  const allEntries = await getCollection('canon', e => !e.id.startsWith('novels/'));

  const paths = [];
  for (const [collection, label] of Object.entries(LABELS)) {
    const allInCollection = allEntries
      .filter(e => e.data.collection === collection)
      .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

    // Stories only (exclude the overview post whose title === collection label) — used for prev/next
    const stories = allInCollection.filter(e => e.data.title !== label);

    for (const entry of allInCollection) {
      const slug = entry.id.split('/').pop();
      if (!slug) continue;
      const storyIndex = stories.indexOf(entry);
      paths.push({
        params: { collection, slug },
        props: {
          entry,
          collectionLabel: label,
          // Overview post has storyIndex -1 — no prev/next
          prev: storyIndex > 0 ? { title: stories[storyIndex - 1].data.title, href: `${import.meta.env.BASE_URL}canon/${collection}/${stories[storyIndex - 1].id.split('/').pop()}/` } : null,
          next: storyIndex >= 0 && storyIndex < stories.length - 1 ? { title: stories[storyIndex + 1].data.title, href: `${import.meta.env.BASE_URL}canon/${collection}/${stories[storyIndex + 1].id.split('/').pop()}/` } : null,
        },
      });
    }
  }
  return paths;
}

const { collection } = Astro.params;
const { entry, collectionLabel, prev, next } = Astro.props;
const { Content } = await render(entry);
const { title, description, coverImage } = entry.data;
---
<Base title={title} description={description} image={coverImage?.src}>
  <div class="max-w-[70ch] mx-auto px-4 py-10">
    <Breadcrumb crumbs={[
      { label: 'Home', href: import.meta.env.BASE_URL },
      { label: 'The Canon', href: `${import.meta.env.BASE_URL}canon/` },
      { label: collectionLabel, href: `${import.meta.env.BASE_URL}canon/${collection}/` },
      { label: entry.data.title },
    ]} />

    <h1 class="font-serif text-3xl font-semibold text-stone-900 mb-8">{entry.data.title}</h1>

    <article class="prose">
      <Content />
    </article>

    <StoryNav prev={prev} next={next} />
  </div>
</Base>
