---
// Handles /canon/adventures/, /canon/memoirs/, /canon/return/, /canon/casebook/, /canon/last-bow/
// (NOT /canon/novels/ — that has its own dedicated page)
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

const LABELS: Record<string, string> = {
  adventures: 'The Adventures of Sherlock Holmes',
  memoirs:    'The Memoirs of Sherlock Holmes',
  return:     'The Return of Sherlock Holmes',
  'last-bow': 'His Last Bow',
  casebook:   'The Case-Book of Sherlock Holmes',
};

const INTRO_SLUGS: Record<string, string> = {
  adventures: 'the-adventures-of-sherlock-holmes',
  memoirs:    'the-memoirs-of-sherlock-holmes',
  return:     'the-return-of-sherlock-holmes',
  'last-bow': 'his-last-bow',
  casebook:   'the-case-book-of-sherlock-holmes',
};

export async function getStaticPaths() {
  const LABELS: Record<string, string> = {
    adventures: 'The Adventures of Sherlock Holmes',
    memoirs:    'The Memoirs of Sherlock Holmes',
    return:     'The Return of Sherlock Holmes',
    'last-bow': 'His Last Bow',
    casebook:   'The Case-Book of Sherlock Holmes',
  };

  const INTRO_SLUGS: Record<string, string> = {
    adventures: 'the-adventures-of-sherlock-holmes',
    memoirs:    'the-memoirs-of-sherlock-holmes',
    return:     'the-return-of-sherlock-holmes',
    'last-bow': 'his-last-bow',
    casebook:   'the-case-book-of-sherlock-holmes',
  };

  const allEntries = await getCollection('canon');

  return Object.keys(LABELS).map(collection => {
    const introSlug = INTRO_SLUGS[collection];
    const entries = allEntries
      .filter(e => e.data.collection === collection)
      .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
    const introEntry = entries.find(e => e.id.split('/').pop() === introSlug) ?? null;
    const stories = entries.filter(e => e.id.split('/').pop() !== introSlug);
    return { params: { collection }, props: { stories, introEntry, label: LABELS[collection] } };
  });
}

const { collection } = Astro.params;
const { stories, introEntry, label } = Astro.props;
const description = introEntry?.data.description ?? `Read all the stories from "${label}", one of the classic Sherlock Holmes short story collections by Sir Arthur Conan Doyle.`;
const { Content: IntroContent } = introEntry ? await render(introEntry) : { Content: null };
---
<Base title={label} description={description} image={introEntry?.data.coverImage?.src}>
  <div class="max-w-[70ch] mx-auto px-4 py-10">
    <Breadcrumb crumbs={[
      { label: 'Home', href: import.meta.env.BASE_URL },
      { label: 'The Canon', href: `${import.meta.env.BASE_URL}canon/` },
      { label: label },
    ]} />

    <h1 class="font-serif text-3xl font-semibold text-stone-900 mb-6">{label}</h1>

    {IntroContent && (
      <article class="prose mb-8">
        <IntroContent />
      </article>
    )}

    <h2 class="font-serif text-xl font-semibold text-stone-700 mb-4">Stories in this collection</h2>
    <ol class="space-y-1">
      {stories.map((entry, i) => {
        const slug = entry.id.split('/').pop();
        if (!slug) return null;
        return (
          <li>
            <a
              href={`${import.meta.env.BASE_URL}canon/${collection}/${slug}/`}
              class="flex items-baseline gap-3 px-4 py-3 rounded-lg hover:bg-amber-50 hover:text-amber-900 group transition-colors"
            >
              <span class="text-stone-400 text-sm w-6 shrink-0 text-right">{i + 1}.</span>
              <span class="font-serif text-stone-800 group-hover:text-amber-900">{entry.data.title}</span>
            </a>
          </li>
        );
      })}
    </ol>
  </div>
</Base>
