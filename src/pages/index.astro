---
import Base from '../layouts/Base.astro';

const collections = [
  { slug: 'adventures', title: 'The Adventures of Sherlock Holmes', count: 12, year: '1892' },
  { slug: 'memoirs',    title: 'The Memoirs of Sherlock Holmes',    count: 11, year: '1894' },
  { slug: 'return',     title: 'The Return of Sherlock Holmes',     count: 13, year: '1905' },
  { slug: 'last-bow',   title: 'His Last Bow',                      count: 8,  year: '1917' },
  { slug: 'casebook',   title: 'The Case Book of Sherlock Holmes',  count: 13, year: '1927' },
];

const novels = [
  { slug: 'novels/a-study-in-scarlet',        title: 'A Study in Scarlet',            year: '1887' },
  { slug: 'novels/sign-of-four',              title: 'The Sign of Four',              year: '1890' },
  { slug: 'novels/hound-of-the-baskervilles', title: 'The Hound of the Baskervilles', year: '1902' },
  { slug: 'novels/valley-of-fear',            title: 'The Valley of Fear',            year: '1915' },
];
---
<Base title="Home">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="text-center mb-14">
      <h1 class="font-serif text-4xl font-semibold text-stone-900 mb-3">Sir Arthur Conan Doyle</h1>
      <p class="text-stone-600 text-lg max-w-xl mx-auto">His Life, All His Works and More</p>
    </div>

    <section class="mb-14">
      <p class="text-stone-700 mb-6 text-base leading-relaxed">Welcome to Sir Arthur Conan Doyle – His Life, All His Works and More, a leading website bringing you the works of Sir Arthur Conan Doyle including his most popular creation Sherlock Holmes.</p>

      <h2 class="font-serif text-2xl text-stone-800 mb-1">The Sherlock Holmes Canon</h2>
      <p class="text-sm text-stone-500 mb-6">4 novels · 56 short stories</p>

      <div class="mb-6">
        <h3 class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-3">Novels</h3>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {novels.map(n => (
            <li>
              <a href={`/canon/${n.slug}/`} class="flex justify-between items-baseline px-4 py-3 rounded-lg border border-stone-200 hover:border-amber-300 hover:bg-amber-50 transition-colors group">
                <span class="font-serif text-stone-800 group-hover:text-amber-900">{n.title}</span>
                <span class="text-xs text-stone-400 ml-3 shrink-0">{n.year}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-3">Short Story Collections</h3>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {collections.map(c => (
            <li>
              <a href={`/canon/${c.slug}/`} class="flex justify-between items-baseline px-4 py-3 rounded-lg border border-stone-200 hover:border-amber-300 hover:bg-amber-50 transition-colors group">
                <span class="font-serif text-stone-800 group-hover:text-amber-900">{c.title}</span>
                <span class="text-xs text-stone-400 ml-3 shrink-0">{c.count} stories</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl text-stone-800 mb-1">Other Works</h2>
      <p class="text-sm text-stone-500 mb-4">Novels, novellas, and short story collections beyond Holmes</p>
      <a href="/novels/" class="inline-block px-4 py-2 border border-stone-300 rounded-lg text-stone-700 hover:border-amber-400 hover:text-amber-900 transition-colors text-sm">
        Browse all novels &amp; collections →
      </a>
    </section>
  </div>
</Base>
