---
import Base from '../layouts/Base.astro';

const collections = [
  { slug: 'adventures', title: 'The Adventures of Sherlock Holmes', count: 12, year: '1892' },
  { slug: 'memoirs',    title: 'The Memoirs of Sherlock Holmes',    count: 11, year: '1894' },
  { slug: 'return',     title: 'The Return of Sherlock Holmes',     count: 13, year: '1905' },
  { slug: 'last-bow',   title: 'His Last Bow',                      count: 8,  year: '1917' },
  { slug: 'casebook',   title: 'The Case Book of Sherlock Holmes',  count: 13, year: '1927' },
];

const novels = [
  { slug: 'novels/a-study-in-scarlet',        title: 'A Study in Scarlet',            year: '1887' },
  { slug: 'novels/sign-of-four',              title: 'The Sign of Four',              year: '1890' },
  { slug: 'novels/hound-of-the-baskervilles', title: 'The Hound of the Baskervilles', year: '1902' },
  { slug: 'novels/valley-of-fear',            title: 'The Valley of Fear',            year: '1915' },
];
---
<Base title="Home">
  <!-- Hero Section -->
  <div class="relative bg-gradient-to-b from-[#2a241b] to-[#1a1410] pt-24 pb-20 border-b border-[#d4af37]">
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle, #d4af37 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="max-w-4xl mx-auto px-4 relative">
      <div class="text-center">
        <div class="mb-6 flex justify-center">
          <div class="h-1 w-20 bg-gradient-to-r from-[#d4af37] to-[#c9a961]"></div>
        </div>
        <h1 class="font-serif text-5xl md:text-6xl font-semibold text-[#d4af37] mb-4 tracking-tight" style="text-shadow: 0 4px 20px rgba(212, 175, 55, 0.3);">Sir Arthur Conan Doyle</h1>
        <p class="text-[#c9a961] text-lg md:text-xl max-w-2xl mx-auto font-light tracking-wide">The complete works — Sherlock Holmes, Professor Challenger, and beyond.</p>
        <div class="mt-6 flex justify-center">
          <div class="h-1 w-20 bg-gradient-to-r from-[#c9a961] to-[#d4af37]"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-16">
    <!-- Sherlock Holmes Canon Section -->
    <section class="mb-20">
      <div class="mb-10">
        <div class="flex items-center gap-4 mb-3">
          <h2 class="font-serif text-3xl text-[#d4af37]">The Sherlock Holmes Canon</h2>
          <div class="flex-1 h-0.5 bg-gradient-to-r from-[#d4af37] to-transparent"></div>
        </div>
        <p class="text-[#8b7355] text-base">4 novels · 56 short stories</p>
      </div>

      <!-- Novels -->
      <div class="mb-12">
        <h3 class="text-xs font-semibold uppercase tracking-widest text-[#c9a961] mb-4 pl-4 border-l-2 border-[#d4af37]">The Novels</h3>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {novels.map(n => (
            <li>
              <a href={`/canon/${n.slug}/`} class="group block px-5 py-4 rounded-lg border border-[#3d2817] bg-[#2a241b] hover:border-[#d4af37] hover:bg-[#3d2817] transition-all duration-300 hover:shadow-lg" style="box-shadow: 0 0 0 0 rgba(212, 175, 55, 0);">
                <div class="flex justify-between items-start gap-3">
                  <span class="font-serif text-[#e8dcc8] group-hover:text-[#d4af37] transition-colors duration-300 flex-1">{n.title}</span>
                  <span class="text-xs text-[#8b7355] group-hover:text-[#c9a961] whitespace-nowrap ml-2 transition-colors duration-300">{n.year}</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Collections -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-[#c9a961] mb-4 pl-4 border-l-2 border-[#d4af37]">Short Story Collections</h3>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {collections.map(c => (
            <li>
              <a href={`/canon/${c.slug}/`} class="group block px-5 py-4 rounded-lg border border-[#3d2817] bg-[#2a241b] hover:border-[#d4af37] hover:bg-[#3d2817] transition-all duration-300 hover:shadow-lg" style="box-shadow: 0 0 0 0 rgba(212, 175, 55, 0);">
                <div class="flex justify-between items-start gap-3">
                  <span class="font-serif text-[#e8dcc8] group-hover:text-[#d4af37] transition-colors duration-300 flex-1">{c.title}</span>
                  <span class="text-xs text-[#8b7355] group-hover:text-[#c9a961] whitespace-nowrap ml-2 transition-colors duration-300">{c.count} stories</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Other Works Section -->
    <section class="pt-12 border-t border-[#3d2817]">
      <div class="flex items-center gap-4 mb-6">
        <h2 class="font-serif text-3xl text-[#d4af37]">Other Works</h2>
        <div class="flex-1 h-0.5 bg-gradient-to-r from-[#d4af37] to-transparent"></div>
      </div>
      <p class="text-[#8b7355] text-base mb-6">Novels, novellas, and short story collections beyond Holmes</p>
      <a href="/novels/" class="inline-flex items-center px-6 py-3 border border-[#d4af37] rounded-lg text-[#d4af37] hover:text-[#2a241b] hover:bg-[#d4af37] transition-all duration-300 text-sm font-medium tracking-wide group">
        <span>Browse all novels &amp; collections</span>
        <span class="ml-2 group-hover:translate-x-1 transition-transform duration-300">→</span>
      </a>
    </section>
  </div>
</Base>
