---
import Base from '../layouts/Base.astro';
const query = Astro.url.searchParams.get('q') ?? '';
---
<Base title="Search">
  <link slot="head" rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <div class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="font-serif text-3xl font-semibold text-black mb-6">Search</h1>
    <div id="search"></div>
  </div>
</Base>

<script is:inline>
  function initSearch() {
    const query = new URLSearchParams(window.location.search).get('q');
    try {
      if (typeof PagefindUI === 'undefined') {
        throw new Error('PagefindUI is not defined. Ensure /pagefind/pagefind-ui.js is loaded.');
      }
      const ui = new PagefindUI({ element: '#search', showImages: false });
      if (query) {
        setTimeout(() => {
          const input = document.querySelector('#search input[type="text"]');
          if (input) {
            input.value = query;
            input.dispatchEvent(new Event('input', { bubbles: true }));
          }
        }, 150);
      }
    } catch (e) {
      console.error('Pagefind failed to load:', e);
      const el = document.getElementById('search');
      if (el) el.innerHTML = '<p class="text-stone-500 text-sm py-4">Search is only available in the production build. Please wait for <code>./scripts/test-search.sh</code> to complete and then refresh.</p>';
    }
  }

  // Handle script loading
  const script = document.createElement('script');
  script.src = '/pagefind/pagefind-ui.js';
  script.onload = initSearch;
  script.onerror = () => {
    console.error('Failed to load /pagefind/pagefind-ui.js');
    initSearch(); // Trigger catch block
  };
  document.head.appendChild(script);
</script>
