---
import Base from '../layouts/Base.astro';
const query = Astro.url.searchParams.get('q') ?? '';
---
<Base title="Search">
  <link slot="head" rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <div class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="font-serif text-3xl font-semibold text-black mb-6">Search</h1>
    <div id="search"></div>
  </div>
</Base>

<script define:vars={{ query }}>
  async function initSearch() {
    try {
      const { PagefindUI } = await import('/pagefind/pagefind-ui.js');
      const ui = new PagefindUI({ element: '#search', showImages: false });
      if (query) {
        await new Promise(r => setTimeout(r, 150));
        const input = document.querySelector('#search input[type="text"]');
        if (input) {
          input.value = query;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }
    } catch {
      const el = document.getElementById('search');
      if (el) el.innerHTML = '<p class="text-stone-500 text-sm py-4">Search is only available in the production build. Run <code class="bg-stone-100 px-1 rounded">npm run build &amp;&amp; npm run preview</code> to test search locally.</p>';
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearch);
  } else {
    initSearch();
  }
</script>
